{
    "name": "pearblog/engine",
    "description": "PearBlog Engine – WordPress content automation engine",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "PearBlogEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PearBlogEngine\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}
