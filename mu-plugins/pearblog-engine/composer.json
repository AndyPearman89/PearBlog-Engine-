{
	"name": "andypearman/pearblog-engine",
	"description": "PearBlog SaaS Engine – autonomous AI content production system.",
	"type": "wordpress-muplugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"autoload": {
		"psr-4": {
			"PearBlogEngine\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"PearBlogEngine\\Tests\\": "tests/php/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:unit": "phpunit --testsuite=Unit"
	},
	"config": {
		"sort-packages": true,
		"allow-plugins": {}
	}
}
