#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMAND="${1:-}"

usage() {
  echo "Usage: ./run dev | ./run test [phpunit-args]" >&2
}

run_dev() {
  echo "Running PearBlog development sanity checks..."

  if command -v php >/dev/null 2>&1; then
    while IFS= read -r -d '' file; do
      if ! php -l "$file" >/dev/null; then
        echo "✗ PHP syntax error in: $file" >&2
        php -l "$file" >&2
        exit 1
      fi
    done < <(find "$ROOT_DIR/mu-plugins/pearblog-engine/src" -name '*.php' -print0)
    echo "✓ PHP syntax check passed"
  else
    echo "⚠ php not found; skipping syntax check"
  fi

  echo "Development sanity checks passed."
}

run_test() {
  local plugin_dir="$ROOT_DIR/mu-plugins/pearblog-engine"
  echo "Running PearBlog PHPUnit checks with Composer-managed PHPUnit..."

  if ! command -v php >/dev/null 2>&1; then
    echo "✗ php not found; cannot run PHPUnit checks" >&2
    exit 1
  fi

  if [ ! -x "$plugin_dir/vendor/bin/phpunit" ]; then
    if command -v composer >/dev/null 2>&1; then
      echo "Installing Composer dependencies for test execution..."
      (cd "$plugin_dir" && composer install --no-interaction --no-progress --prefer-dist)
    else
      echo "✗ vendor/bin/phpunit not found and composer is unavailable" >&2
      echo "  Run 'composer install' in $plugin_dir before executing tests." >&2
      exit 1
    fi
  fi

  (
    cd "$plugin_dir"
    ./vendor/bin/phpunit -c phpunit.xml "${@:1}"
  )
}

case "$COMMAND" in
  dev)
    run_dev
    ;;
  test)
    run_test "${@:2}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
