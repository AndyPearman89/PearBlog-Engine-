#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMAND="${1:-}"

usage() {
  echo "Usage: ./run dev | ./run test [phpunit-args]" >&2
}

run_dev() {
  echo "Running PearBlog development sanity checks..."

  if command -v php >/dev/null 2>&1; then
    while IFS= read -r -d '' file; do
      if ! php -l "$file" >/dev/null; then
        echo "✗ PHP syntax error in: $file" >&2
        php -l "$file" >&2
        exit 1
      fi
    done < <(find "$ROOT_DIR/mu-plugins/pearblog-engine/src" -name '*.php' -print0)
    echo "✓ PHP syntax check passed"
  else
    echo "⚠ php not found; skipping syntax check"
  fi

  echo "Development sanity checks passed."
}

run_test() {
  local plugin_dir="$ROOT_DIR/mu-plugins/pearblog-engine"
  local -a phpunit_cmd
  local -a phpunit_args
  local legacy_config=""
  echo "Running PearBlog PHPUnit checks..."

  if ! command -v php >/dev/null 2>&1; then
    echo "✗ php not found; cannot run PHPUnit checks" >&2
    exit 1
  fi

  if [ -x "$plugin_dir/vendor/bin/phpunit" ]; then
    phpunit_cmd=(./vendor/bin/phpunit)
    phpunit_args=(-c phpunit.xml "${@:1}")
    echo "Using vendor/bin/phpunit"
  elif command -v phpunit >/dev/null 2>&1; then
    phpunit_cmd=(phpunit)
    legacy_config="$(mktemp -t pearblog-phpunit-legacy-XXXXXX.xml)"
    cat > "$legacy_config" <<EOF
<?xml version="1.0"?>
<phpunit bootstrap="$plugin_dir/tests/php/bootstrap.php" colors="true" cacheResultFile="$plugin_dir/.phpunit.result.cache">
  <testsuites>
    <testsuite name="Unit">
      <directory>$plugin_dir/tests/php/Unit</directory>
    </testsuite>
    <testsuite name="Integration">
      <directory>$plugin_dir/tests/php/Integration</directory>
    </testsuite>
  </testsuites>
</phpunit>
EOF
    phpunit_args=(-c "$legacy_config" "${@:1}")
    echo "⚠ vendor/bin/phpunit not found; using system phpunit"
  else
    echo "✗ PHPUnit is unavailable (no vendor/bin/phpunit and no global phpunit)" >&2
    echo "  Run 'composer install' in $plugin_dir to install vendor/bin/phpunit." >&2
    exit 1
  fi

  # Prevent RuntimeException in some phpunit environments lacking request start globals.
  export REQUEST_TIME="${REQUEST_TIME:-$(date +%s)}"
  if [ -z "${REQUEST_TIME_FLOAT:-}" ]; then
    local request_time_float
    request_time_float="$(date +%s.%6N 2>/dev/null || true)"
    if [ -z "$request_time_float" ] || [[ "$request_time_float" == *N* ]]; then
      request_time_float="$(php -r 'echo microtime(true);')"
    fi
    export REQUEST_TIME_FLOAT="$request_time_float"
  fi

  (
    cd "$plugin_dir"
    "${phpunit_cmd[@]}" "${phpunit_args[@]}"
  )

  if [ -n "$legacy_config" ] && [ -f "$legacy_config" ]; then
    rm -f "$legacy_config"
  fi
}

case "$COMMAND" in
  dev)
    run_dev
    ;;
  test)
    run_test "${@:2}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
