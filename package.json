{
  "name": "pearblog-engine-tests",
  "version": "3.3.0",
  "description": "PT24 E2E and Unit Tests",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "cd mu-plugins/pearblog-engine && phpunit",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:headless": "cypress run --headless",
    "test:performance": "npm run test:lighthouse",
    "test:lighthouse": "lighthouse https://pt24.pro --output json --output html",
    "test:security": "bash scripts/security-audit.sh",
    "lint:php": "phpcs theme/pearblog-theme/inc/pt24*.php",
    "lint:css": "stylelint theme/pearblog-theme/assets/css/pt24*.css",
    "format:css": "prettier --write theme/pearblog-theme/assets/css/pt24*.css",
    "minify:css": "csso theme/pearblog-theme/assets/css/pt24-site.css -o theme/pearblog-theme/assets/css/pt24-site.min.css"
  },
  "keywords": ["pt24", "e2e", "testing", "cypress"],
  "author": "Andy Pearman",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "cypress": "^13.6.2",
    "lighthouse": "^11.0.0",
    "@cypress/schematic": "^2.5.1"
  }
}
